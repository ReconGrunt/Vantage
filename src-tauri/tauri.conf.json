{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Vantage",
  "version": "0.1.0",
  "identifier": "com.vantage.desktop",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ReconGrunt/vantage/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
